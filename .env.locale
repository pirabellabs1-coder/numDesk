# ============================================
# Vocalia — Variables d'environnement
# Copier ce fichier vers .env.local et remplir les valeurs
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# --- Vapi (Orchestrateur vocal) ---
VAPI_API_KEY=vapi_xxxxxxxxxxxxxxxx
VAPI_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# --- Stripe (Paiement & facturation) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx

# --- Telnyx (Téléphonie SIP) ---
TELNYX_API_KEY=KEY_xxxxxxxxxxxxxxxx
TELNYX_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# --- Twilio (Téléphonie fallback) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx

# --- LLM (Modèles de conversation) ---
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# --- TTS (Voix) ---
CARTESIA_API_KEY=sk_cart_xxxxxxxxxxxxxxxx
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxx

# --- Resend (Emails transactionnels) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@vocalia.app

# --- Redis (Worker — BullMQ queues) ---
REDIS_URL=redis://default:xxxxxxxx@xxxxx.railway.app:6379

# --- Sentry (Error tracking) ---
SENTRY_DSN=https://xxxxxxxx@o123456.ingest.sentry.io/123456
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@o123456.ingest.sentry.io/123456
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxx

# --- PostHog (Analytics produit) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKER_PORT=3001
NODE_ENV=development
